    "def choose_n_configs( N, data ):\n",
    "    if ( len(data) < N ):\n",
    "        return data\n",
    "    if N == 1:\n",
    "        return [ data[0]]\n",
    "    if N == 2:\n",
    "        return [ data[0], data[-1] ]\n",
    "    indices =  [ int(i) for i in np.linspace( 0, len(data)-1, N, endpoint=True) ]\n",
    "    return [ data[i] for i in indices ] \n",
    "\n",
